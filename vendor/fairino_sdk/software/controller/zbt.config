#This is the configure file of the QBOT control system

#General note: Comments can be preceded with #

#Setting with a + at the front of the comment are likely needed to be changed by the user
#Setting with a - at the front of the comment are highly unneeded to be changed

#The units used in the system for calculation are:
#Length:				mm
#Linear velocity:		mm/s
#Linear acc:			mm/s^2
#Angle: 				deg
#Angular velocity:		deg/s
#Angular acc:			deg/s^2

################################################################################
# General section
################################################################################
[QBOT]
# - Name of machine
MACHINE = QBOT-SCARA-AXES4-QS3

# + Version of this configure file
VERSION = 000-000-008

################################################################################
# Trajectory planner section
# MAXAXES     :  9
# AXES        :  4
# COORDINATES : X Y Z U V W
# HOME        : 0 0 0 0 90 0
################################################################################
[ROBOT_PARAM]
SAMPLE_TIME =  0.001
BOT_AXES_NO =  6
AUX_AXES_NO =  4

SLAVE_NUM = 8

PIO_IN_NO  =  16
AIO_IN_NO  =  2
PIO_OUT_NO =  16
AIO_OUT_NO =  2
AXLE_PIO_IN_NO  =  5
AXLE_AIO_IN_NO  =  1
AXLE_PIO_OUT_NO =  2
AXLE_AIO_OUT_NO =  1

MORTOR_60_RATED_TORQUE = 0.32
MORTOR_60L_RATED_TORQUE = 0.64
MORTOR_80_RATED_TORQUE = 1
MORTOR_130_RATED_TORQUE = 3.8
MORTOR_130L_RATED_TORQUE = 7.2

[TRAJ_PLANNER]
MAX_LINEAR_VELOCITY =			1000.0
MAX_LINEAR_ACCELERATION = 		2000.0
MAX_LINEAR_JERK =               4000.0

MAX_ANGULAR_VELOCITY =			360.0
MAX_ANGULAR_ACCELERATION = 		720.0
MAX_ANGULAR_JERK =              1080.0


################################################################################
# Joint & IO section
################################################################################
[JOINTS]
J0_CALIB             =      1
J0_MAX_PHY_POS_LIMIT =      180
J0_MIN_PHY_POS_LIMIT =      -180
J0_VEL_LIMIT          =     180
J0_ACC_LIMIT          =     360
J0_JPOS_FERROR_LIMIT  =     10
J0_JPOS_FUZZ   =            0.000001
J0_ENCODER_RESOLUTION =     16384
J0_GEAR_RATIO         =     101
J0_ENCODER_OFFSET      =    0

J1_CALIB             =      1
J1_MAX_PHY_POS_LIMIT =      180
J1_MIN_PHY_POS_LIMIT =      -180
J1_VEL_LIMIT          =     180
J1_ACC_LIMIT          =     360
J1_JPOS_FERROR_LIMIT  =     10
J1_JPOS_FUZZ   =            0.000001
J1_ENCODER_RESOLUTION =     16384
J1_GEAR_RATIO         =     101
J1_ENCODER_OFFSET      =    0

J2_CALIB             =      1
J2_MAX_PHY_POS_LIMIT =      180
J2_MIN_PHY_POS_LIMIT =      -180
J2_VEL_LIMIT          =     180
J2_ACC_LIMIT          =     360
J2_JPOS_FERROR_LIMIT  =     10
J2_JPOS_FUZZ   =            0.000001
J2_ENCODER_RESOLUTION =     16384
J2_GEAR_RATIO         =     101
J2_ENCODER_OFFSET      =    0

J3_CALIB             =      1
J3_MAX_PHY_POS_LIMIT =      180
J3_MIN_PHY_POS_LIMIT =      -180
J3_VEL_LIMIT          =     180
J3_ACC_LIMIT          =     360
J3_JPOS_FERROR_LIMIT  =     10
J3_JPOS_FUZZ   =            0.000001
J3_ENCODER_RESOLUTION =     16384
J3_GEAR_RATIO         =     101
J3_ENCODER_OFFSET      =    0


################################################################################
# by likai
################################################################################
J4_CALIB             =      1
J4_MAX_PHY_POS_LIMIT =      180
J4_MIN_PHY_POS_LIMIT =      -180
J4_VEL_LIMIT          =     180
J4_ACC_LIMIT          =     360
J4_JPOS_FERROR_LIMIT  =     10
J4_JPOS_FUZZ   =            0.000001
J4_ENCODER_RESOLUTION =     16384
J4_GEAR_RATIO         =     101
J4_ENCODER_OFFSET      =    0

J5_CALIB             =      1
J5_MAX_PHY_POS_LIMIT =      180
J5_MIN_PHY_POS_LIMIT =      -180
J5_VEL_LIMIT          =     180
J5_ACC_LIMIT          =     360
J5_JPOS_FERROR_LIMIT  =     10
J5_JPOS_FUZZ   =            0.000001
J5_ENCODER_RESOLUTION =     16384
J5_GEAR_RATIO         =     101
